[Unit]
Description=Here Server - Location receiver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/here-server
Restart=always
RestartSec=5
EnvironmentFile=-/etc/here-server/env
DynamicUser=yes
StateDirectory=here-server
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
